{
  "name": "saber11-backend",
  "version": "1.1.0",
  "private": true,
  "description": "Backend para plataforma de evaluacion academica tipo Saber 11.",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "seed": "ts-node prisma/seed.ts",
    "bootstrap:admin": "ts-node scripts/bootstrap_admin.ts",
    "db:reset:dev": "ts-node scripts/db_reset_dev.ts --confirm",
    "test:integration": "ts-node --files tests/integration/run.ts",
    "ingest:icfes:cuadernillos": "ts-node scripts/ingest_icfes_cuadernillos.ts",
    "download:icfes:pasados": "ts-node scripts/download_icfes_examenes_pasados.ts",
    "extract:icfes:questions": "ts-node scripts/extract_icfes_questions.ts",
    "ingest:icfes:questions": "ts-node scripts/ingest_icfes_questions.ts",
    "pipeline:icfes:questions": "npm run extract:icfes:questions && npm run ingest:icfes:questions -- --apply",
    "ingest:kb": "ts-node scripts/ingest_knowledge_base.ts",
    "ingest:kb:apply": "ts-node scripts/ingest_knowledge_base.ts --apply",
    "mcp:server": "ts-node scripts/mcp_exam_server.ts",
    "seed:colegios:magdalena": "ts-node scripts/import_magdalena_schools.ts --apply",
    "seed:colegios:magdalena:dry": "ts-node scripts/import_magdalena_schools.ts"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.3.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.10.0",
    "multer": "^2.0.2",
    "node-xlsx": "^0.24.0",
    "pdf-parse": "^1.1.1",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "rate-limiter-flexible": "^5.0.4",
    "swagger-ui-express": "^5.0.1",
    "tesseract.js": "^6.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.16.5",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.7",
    "prisma": "^5.20.0",
    "supertest": "^7.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
